@page "/products"
@attribute [StreamRendering(true)]

@inject CatalogApiClient CatalogApi

<PageTitle>Products</PageTitle>

<h1>Product Catalog</h1>

<p>
    Data flows: <strong>Web</strong> → <strong>ApiService</strong> → <strong>CatalogService</strong> → <strong>PostgreSQL</strong>.
    Each hop is a separate traced request visible in the Aspire dashboard.
</p>

@if (products == null)
{
    <p><em>Loading products from catalog service...</em></p>
}
else if (products.Length == 0)
{
    <p>No products found.</p>
}
else
{
    @foreach (var category in products.GroupBy(p => p.Category).OrderBy(g => g.Key))
    {
        <h3 class="mt-4">@category.Key</h3>
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3 mb-3">
            @foreach (var product in category.OrderBy(p => p.Name))
            {
                <div class="col">
                    <div class="card h-100 @(product.IsFeatured ? "border-warning" : "")">
                        @if (product.IsFeatured)
                        {
                            <div class="card-header bg-warning text-dark fw-bold">⭐ Featured</div>
                        }
                        <div class="card-body">
                            <h5 class="card-title">@product.Name</h5>
                            <p class="card-text text-muted">@product.Description</p>
                        </div>
                        <div class="card-footer d-flex justify-content-between align-items-center">
                            <span class="fs-5 fw-bold">$@product.Price.ToString("N2")</span>
                            <span class="badge @StockBadgeClass(product.StockStatus)">@product.StockStatus</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    private ProductSummary[]? products;

    protected override async Task OnInitializedAsync()
    {
        products = await CatalogApi.GetProductsAsync();
    }

    private static string StockBadgeClass(string status) => status switch
    {
        "Out of stock" => "bg-danger",
        "Low stock"    => "bg-warning text-dark",
        _              => "bg-success"
    };
}
