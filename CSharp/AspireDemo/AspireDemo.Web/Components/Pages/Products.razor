@page "/products"

@inject CatalogApiClient CatalogApi

<PageTitle>Products</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Product Catalog</MudText>
<MudText Class="mb-6">
    Data flows: <strong>Web → ApiService → CatalogService → PostgreSQL</strong>.
    Each hop is a separate traced request visible in the Aspire dashboard.
</MudText>

@if (products == null)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}
else if (products.Length == 0)
{
    <MudAlert Severity="Severity.Info">No products found.</MudAlert>
}
else
{
    @foreach (var category in products.GroupBy(p => p.Category).OrderBy(g => g.Key))
    {
        <MudText Typo="Typo.h5" Class="mt-6 mb-3">@category.Key</MudText>
        <MudGrid>
            @foreach (var product in category.OrderBy(p => p.Name))
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="2" Style="height:100%">
                        @if (product.IsFeatured)
                        {
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudChip T="string" Color="Color.Warning" Icon="@Icons.Material.Filled.Star" Size="Size.Small">Featured</MudChip>
                                </CardHeaderContent>
                            </MudCardHeader>
                        }
                        <MudCardContent>
                            <MudText Typo="Typo.h6">@product.Name</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@product.Description</MudText>
                        </MudCardContent>
                        <MudCardActions Class="justify-space-between px-4 pb-3">
                            <MudText Typo="Typo.h6">$@product.Price.ToString("N2")</MudText>
                            <MudChip T="string" Color="@StockColor(product.StockStatus)" Size="Size.Small">@product.StockStatus</MudChip>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
}

@code {
    private ProductSummary[]? products;

    protected override async Task OnInitializedAsync()
    {
        products = await CatalogApi.GetProductsAsync();
    }

    private static Color StockColor(string status) => status switch
    {
        "Out of stock" => Color.Error,
        "Low stock"    => Color.Warning,
        _              => Color.Success
    };
}
