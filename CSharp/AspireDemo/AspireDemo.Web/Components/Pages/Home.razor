@page "/"

<PageTitle>Home — Aspire Demo</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Aspire Demo</MudText>
<MudText Class="mb-6">
    This app demonstrates <strong>.NET Aspire</strong> — service orchestration, distributed tracing, and PostgreSQL integration.
</MudText>

<MudText Typo="Typo.h5" GutterBottom="true">Architecture</MudText>
<MudPaper Elevation="2" Class="pa-4 mb-6">
    <MudText Typo="Typo.body2" Style="font-family: monospace; white-space: pre;">
  [Browser]
      │  HTTP
      ▼
  webfrontend  (Blazor Server)
      │  HTTP via service discovery
      ▼
  apiservice   (ASP.NET Core — gateway / BFF)
      │  HTTP via service discovery
      ▼
  catalogservice (ASP.NET Core — owns the data)
      │  Npgsql + EF Core
      ▼
  postgres     (PostgreSQL in Docker, managed by Aspire)</MudText>
</MudPaper>

<MudText Typo="Typo.h5" GutterBottom="true">Try it out</MudText>
<MudList T="string" Class="mb-6">
    <MudListItem Icon="@Icons.Material.Filled.ShoppingBag">
        <MudLink Href="products">Products</MudLink> — loads from CatalogService → ApiService → PostgreSQL
    </MudListItem>
    <MudListItem Icon="@Icons.Material.Filled.WbSunny">
        <MudLink Href="weather">Weather</MudLink> — loads random data directly from ApiService
    </MudListItem>
</MudList>

<MudAlert Severity="Severity.Info" Class="mb-4">
    <strong>Open the Aspire Dashboard</strong> to see distributed traces, structured logs, and metrics for every service.
    The dashboard URL is printed in the AppHost console on startup.
    Navigate to <strong>Traces</strong> and click any <em>Products</em> request to see the full
    Web → ApiService → CatalogService → Postgres span chain.
</MudAlert>
