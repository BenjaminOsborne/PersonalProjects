@page "/counter"

<PageTitle>Counter</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Counter</MudText>
<MudText Class="mb-4">Current count: <strong>@currentCount</strong></MudText>
<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="IncrementCount" StartIcon="@Icons.Material.Filled.Add">
    Click me
</MudButton>

@code {
    private int currentCount = 0;
    private void IncrementCount() => currentCount++;
}
